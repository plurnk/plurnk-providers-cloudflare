# Cloudflare Workers AI config.
# Override order: .env < .env.<profile> < shell.

# Cloudflare account ID. Required (Workers AI endpoints are account-scoped).
# Find it on the Workers AI dashboard at dash.cloudflare.com.
CLOUDFLARE_ACCOUNT_ID=

# API token with Workers AI permission. Required.
# Create at dash.cloudflare.com/profile/api-tokens.
CLOUDFLARE_API_TOKEN=

# Note: fetch timeout is the universal PLURNK_PROVIDER_FETCH_TIMEOUT
# (set in plurnk-service's env). Workers AI inference is per-request
# billed and usually fast; the default 600000 (10m) is generous.
