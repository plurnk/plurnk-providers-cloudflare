{
    "name": "@plurnk/plurnk-providers-cloudflare",
    "version": "0.2.0",
    "description": "Cloudflare Workers AI provider for plurnk-service. Routes @cf/{...} aliases through Workers AI's OpenAI-compatible relay; resolves real per-token pricing and context_window from /ai/models/search at fromEnv time.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=25"
    },
    "plurnk": {
        "kind": "provider",
        "name": "cloudflare"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^25.8.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "gpt-tokenizer": "^3.4.0",
        "llama-tokenizer-js": "^1.2.2"
    }
}
